/* ═══════════════════════════════════════════════════════
   Bills Calculator TUI — main.tcss
   Theme: Dark terminal, gemini-cli / claude-code style
   ═══════════════════════════════════════════════════════ */

/* ── Global ──────────────────────────────────────────── */
Screen {
    background: #282C34;
    color: #ABB2BF;
}

Header {
    background: #282C34;
    color: #61AFEF;
    border-bottom: solid #3E4451;
}

Footer {
    background: #282C34;
    color: #5C6370;
    border-top: solid #3E4451;
}

/* ── Content area ────────────────────────────────────── */
#content-area {
    height: 1fr;
    padding: 0 2;
    overflow-y: auto;
    scrollbar-color: #3E4451 #282C34;
    scrollbar-size: 1 1;
}

/* ── Figlet hero ─────────────────────────────────────── */
#hero {
    height: auto;
    margin: 1 0;
    padding: 0;
}

/* ── RichLog output area ─────────────────────────────── */
#output-log {
    height: auto;
    min-height: 10;
    margin-bottom: 1;
    padding: 0;
    scrollbar-color: #3E4451 #282C34;
}

/* ── Command bar — CSS handled via DEFAULT_CSS in CommandInput widget ── */

/* ── History screen ──────────────────────────────────── */
HistoryScreen {
    background: #282C34;
}

#history-root {
    height: 1fr;
    padding: 1 2;
}

#history-title {
    text-style: bold;
    color: #61AFEF;
    margin-bottom: 1;
}

#history-table {
    height: 1fr;
    margin-bottom: 1;
    border: round #3E4451;
    background: #282C34;
}

#history-hint {
    color: #5C6370;
}
